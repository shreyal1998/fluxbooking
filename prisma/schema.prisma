// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum BusinessType {
  SALON
  GYM
  CLINIC
}

enum UserRole {
  ADMIN
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NOSHOW
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionPlan {
  FREE
  PRO
  TEAM
}

enum SubscriptionInterval {
  MONTH
  YEAR
}

model Tenant {
  id                String       @id @default(cuid())
  name              String
  slug              String       @unique
  businessType      BusinessType @default(SALON)
  country           String       @default("US") // ISO Country Code (e.g., US, IN, GB)
  currency          String       @default("USD") // Currency Code (e.g., USD, INR, GBP)
  logoUrl           String?
  primaryColor      String       @default("#6366f1")
  businessHoursJson Json?        // Global opening/closing hours
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Subscription & Billing
  plan                SubscriptionPlan     @default(FREE)
  planInterval        SubscriptionInterval @default(MONTH)
  planStatus          String?              @default("TRIALING") // ACTIVE, TRIALING, PAST_DUE, CANCELED
  lemonSqueezyCustomerId    String?        @unique
  lemonSqueezySubscriptionId String?       @unique
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?

  // Notifications & Credits
  emailNotificationsEnabled Boolean @default(true)

  users         User[]
  services      Service[]
  staff         Staff[]
  bookings      Booking[]
  blockedSlots  BlockedSlot[]
  leaveRequests LeaveRequest[]
  customers     Customer[]
  locations     Location[]
}

model Location {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  phone       String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  name          String?
  email         String    @unique
  password      String?
  phone         String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]
  staffProfile  Staff?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  durationMinutes Int
  bufferTime      Int      @default(0)
  price           Decimal  @db.Decimal(10, 2)
  color           String   @default("#6366f1") // Default Indigo
  capacity        Int      @default(1) // 1 for Salons, N for Gym classes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  staff           Staff[]  @relation("StaffServices")
}

model Staff {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String?  @unique
  name             String
  bio              String?
  color            String   @default("#6366f1") // Calendar display color
  availabilityJson Json     // Weekly schedule
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings         Booking[]
  blockedSlots     BlockedSlot[]
  leaveRequests    LeaveRequest[]
  services         Service[] @relation("StaffServices")
}

model Customer {
  id        String         @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  notes     String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@unique([tenantId, email])
}

model Booking {
  id            String        @id @default(cuid())
  tenantId      String
  serviceId     String
  staffId       String
  customerId    String?       // Optional link to Customer
  customerName  String        // Snapshot of name
  customerEmail String        // Snapshot of email
  startTime     DateTime
  endTime       DateTime
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff         Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId, startTime])
}

model BlockedSlot {
  id        String   @id @default(cuid())
  tenantId  String
  staffId   String
  reason    String?
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, startTime])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  tenantId  String
  staffId   String
  type      String      // SICK, PERSONAL, VACATION
  reason    String?
  startTime DateTime
  endTime   DateTime
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff     Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}
